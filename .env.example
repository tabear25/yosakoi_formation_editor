# yosakoi_formation バックエンド用の環境変数（値はダミー）。
# 本番の値は Vercel のプロジェクト設定 → Environment Variables で設定する。
# ローカルの `vercel dev` 用には、このファイルを `.env.local` にコピーして実際の値を入れる。

# チーム共通のログイン情報（この ID/PW が一致すればログインできる）
APP_LOGIN_ID=team
APP_LOGIN_PASSWORD=change-me

# セッショントークンの署名に使うランダムな秘密文字列（十分に長くランダムに）
SESSION_SECRET=replace-with-a-long-random-string

# KV（Vercel KV / Upstash Redis）の接続情報。
# Vercel の Storage 連携を作成すると自動で注入される。ローカルでは手動で設定する。
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Upstash 連携ではこちらの名前になることがある（どちらか一方が設定されていればよい）
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
